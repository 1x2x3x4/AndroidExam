<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_purple_dark" />
            <corners android:radius="0dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/button_purple_dark"
                android:startColor="@color/button_purple_light" />
            <corners android:radius="0dp" />
        </shape>
    </item>
</selector>
