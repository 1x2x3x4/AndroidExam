<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/page_padding"
    android:paddingTop="@dimen/page_top_padding"
    android:paddingEnd="@dimen/page_padding"
    android:paddingBottom="@dimen/page_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_28"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_title"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_open_web"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/button_bg"
            android:text="@string/button_open_web"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="@dimen/text_button" />

        <EditText
            android:id="@+id/et_url"
            android:layout_width="0dp"
            android:layout_height="@dimen/edit_height"
            android:layout_marginStart="@dimen/space_8"
            android:layout_weight="1"
            android:background="@drawable/edittext_selector"
            android:hint="@string/hint_url"
            android:imeOptions="actionNext"
            android:inputType="textUri"
            android:paddingStart="@dimen/edit_horizontal_padding"
            android:paddingTop="0dp"
            android:paddingEnd="@dimen/edit_horizontal_padding"
            android:paddingBottom="0dp"
            android:singleLine="true"
            android:text="@string/default_url"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/text_input" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_send_data"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/button_bg"
            android:text="@string/button_send_data"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="@dimen/text_button" />

        <EditText
            android:id="@+id/et_send_text"
            android:layout_width="0dp"
            android:layout_height="@dimen/edit_height"
            android:layout_marginStart="@dimen/space_8"
            android:layout_weight="1"
            android:background="@drawable/edittext_selector"
            android:hint="@string/hint_send_text"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:paddingStart="@dimen/edit_horizontal_padding"
            android:paddingTop="0dp"
            android:paddingEnd="@dimen/edit_horizontal_padding"
            android:paddingBottom="0dp"
            android:singleLine="true"
            android:text="@string/default_send_text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/text_input" />
    </LinearLayout>
</LinearLayout>
